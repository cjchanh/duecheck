{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DueCheck Delta Report",
  "type": "object",
  "required": [
    "schema_version",
    "engine_version",
    "source_adapter",
    "pulled_at",
    "counts",
    "changes"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "engine_version": { "type": "string" },
    "source_adapter": { "type": "string" },
    "pulled_at": { "type": "string" },
    "counts": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item_id",
          "name",
          "course",
          "change_type",
          "from_status",
          "to_status",
          "from_due_at",
          "to_due_at",
          "due_at_changed",
          "deadline_change",
          "first_seen",
          "last_seen",
          "severity_label"
        ],
        "properties": {
          "item_id": { "type": "string" },
          "name": { "type": "string" },
          "course": { "type": "string" },
          "change_type": { "type": "string" },
          "from_status": { "type": "string" },
          "to_status": { "type": "string" },
          "from_due_at": { "type": "string" },
          "to_due_at": { "type": "string" },
          "due_at_changed": { "type": "boolean" },
          "deadline_change": { "type": "string" },
          "first_seen": { "type": "string" },
          "last_seen": { "type": "string" },
          "severity_label": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
